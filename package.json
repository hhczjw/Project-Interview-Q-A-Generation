{
  "name": "project-resume-skill",
  "version": "1.0.0",
  "description": "根据项目自动生成简历的跨平台 AI Coding Skill",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "export:pdf": "node dist/core/exporter.js --format pdf",
