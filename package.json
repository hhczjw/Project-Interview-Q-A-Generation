  "keywords": ["resume", "skill", "ai-coding", "claude-code", "cursor"],
  "license": "MIT",
  "dependencies": {
    "docx": "^8.5.0",
    "glob": "^10.3.0",
    "mammoth": "^1.8.0",
    "marked": "^12.0.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
